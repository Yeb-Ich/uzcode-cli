{
	"name": "uzcode-cli",
	"version": "0.0.1",
	"license": "MIT",
	"bin": "dist/cli.js",
	"type": "module",
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"start": "node dist/cli.js",
		"bundle": "@yao-pkg/pkg . --output releases/uzcode --targets node18-linux-x64 --public",
		"test": "prettier --check . && xo && ava"
	},
	"pkg": {
		"assets": [
			"dist/**/*"
		],
		"targets": [
			"node18-linux-x64"
		],
		"outputPath": "releases"
	},
	"files": [
		"dist"
	],
	"dependencies": {
		"axios": "^1.15.2",
		"ink": "^4.1.0",
		"ink-spinner": "^5.0.0",
		"ink-text-input": "^5.0.0",
		"meow": "^11.0.0",
		"openai": "^4.95.1",
		"react": "^18.2.0"
	},
	"devDependencies": {
		"@sindresorhus/tsconfig": "^3.0.1",
		"@types/react": "^18.0.32",
		"@vdemedes/prettier-config": "^2.0.1",
		"@yao-pkg/pkg": "^6.18.1",
		"ava": "^5.2.0",
		"chalk": "^5.2.0",
		"esbuild": "^0.28.0",
		"eslint-config-xo-react": "^0.27.0",
		"eslint-plugin-react": "^7.32.2",
		"eslint-plugin-react-hooks": "^4.6.0",
		"ink-testing-library": "^3.0.0",
		"prettier": "^2.8.7",
		"ts-node": "^10.9.1",
		"typescript": "^5.0.3",
		"xo": "^0.53.1"
	},
	"ava": {
		"extensions": {
			"ts": "module",
			"tsx": "module"
		},
		"nodeArguments": [
			"--loader=ts-node/esm"
		]
	},
	"xo": {
		"extends": "xo-react",
		"prettier": true,
		"rules": {
			"react/prop-types": "off"
		}
	},
	"prettier": "@vdemedes/prettier-config"
}
